# --- Bridge service ---
BRIDGE_PORT=13000

# --- Stash (defaults to host.docker.internal:9999 — works on Docker Desktop) ---
STASH_URL=http://host.docker.internal:9999
# STASH_API_KEY=
# STASH_SESSION_COOKIE=

# --- Docker network ---
DOCKER_NETWORK=extractor_network

# --- Site Extractor ---
EXTRACTOR_URL=http://extractor-gateway:12000

# --- Data dir (SQLite cache, working files) ---
DATA_PATH=./data

LOG_LEVEL=INFO

# --- Lifecycle (CLAUDE.md §14, docs/HOW_TO_USE.md §7) ---
# Set false only as a rollback to the legacy single-channel pHash path.
BRIDGE_LIFECYCLE_ENABLED=true
BRIDGE_NEW_SCORING_ENABLED=true

# =====================================================================
# CALIBRATED SCORING VALUES
# =====================================================================
# These are the bridge's calibrated behavior, not arbitrary tuning
# knobs. Defaults below are the empirical peaks from a 491-video Pexels
# corpus sweep — see docs/calibration/CALIBRATION_RESULTS.md for the
# run-by-run analysis. Re-calibration = update these values + re-run
# the sweep harness; do not change without empirical evidence.
# ---------------------------------------------------------------------

# Image hashing (used by featurization AND per-request matching)
BRIDGE_HASH_ALGORITHM=phash
BRIDGE_HASH_SIZE=16

# Match-time scoring
BRIDGE_IMAGE_MODE=cover
BRIDGE_IMAGE_THRESHOLD=0.7
BRIDGE_SEARCH_LIMIT=5
BRIDGE_SPRITE_SAMPLE_SIZE=8
BRIDGE_IMAGE_GAMMA=3.5             # Run 3a peak
BRIDGE_IMAGE_COUNT_K=0.25          # Run 3c peak
BRIDGE_IMAGE_MIN_CONTRIBUTION=0.05 # Run 3b peak
BRIDGE_IMAGE_BONUS_PER_EXTRA=0.1
BRIDGE_IMAGE_CHANNELS=phash,color_hist,tone

# Search-mode confidence floor — drops weak image-only candidates
# below this composite. Default empty/None — Run 6 confirmed no global
# value separates weak-correct from weak-incorrect on the Pexels corpus.
# Sharper-corpus deployments may set 0.10–0.20.
# BRIDGE_IMAGE_SEARCH_FLOOR=

# Per-image c_i smoothing (consumed at featurization time and baked
# into stored uniqueness values; re-featurize after changing).
BRIDGE_FEATURIZE_UNIQUENESS_ALPHA=1.0      # Run 5b flat
BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD=0.85 # Run 5a peak
# Optional per-channel overrides — escape hatch for corpora where one
# channel needs distinct tuning (e.g., monochrome film where tone is a
# strong discriminator). On the Pexels calibration corpus all four
# sweeps confirmed the global defaults outperform any per-channel
# override (Run 7).
# BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD_PHASH=
# BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD_TONE=
# BRIDGE_FEATURIZE_UNIQUENESS_ALPHA_PHASH=
# BRIDGE_FEATURIZE_UNIQUENESS_ALPHA_TONE=

# =====================================================================
# OPERATIONAL TUNING (depends on hardware / deployment, not corpus)
# =====================================================================

BRIDGE_FEATURIZE_CONCURRENCY=4
BRIDGE_FEATURIZE_PER_JOB_CONCURRENCY=8
# 'featurizing' rows older than this on boot are reset and re-enqueued
BRIDGE_STALE_TASK_MS=600000

# LRU eviction for Stash-side image_features (Phase 6).
# Set BUDGET to 0 to disable eviction entirely.
BRIDGE_STASH_FEATURE_BUDGET_BYTES=1073741824
BRIDGE_LRU_EVICTION_INTERVAL_S=3600

# Phase 7 soft retirement of the legacy image_hashes table.
# Leave true while validating the new image_features path. Flip false to
# stop dual-writing pHash and skip the legacy fallback. The DROP TABLE
# is a one-time manual op — see docs/HOW_TO_USE.md §7.3.
BRIDGE_LEGACY_DUAL_WRITE_ENABLED=true
