# Bridge service
BRIDGE_PORT=13000

# Stash (defaults to host.docker.internal:9999 — works on Docker Desktop)
STASH_URL=http://host.docker.internal:9999
# STASH_API_KEY=
# STASH_SESSION_COOKIE=

# Docker network (resolves over the shared stash_network)
DOCKER_NETWORK=extractor_network

# Site Extractor (resolves over the shared extractor_network)
EXTRACTOR_URL=http://extractor-gateway:12000

# Data dir (SQLite cache, working files)
DATA_PATH=./data

LOG_LEVEL=INFO

# --- Multi-channel scoring lifecycle (CLAUDE.md §14, docs/HOW_TO_USE.md) ---
# Master toggle for eager featurization + 503 request gate. Leave false
# until you've run a smoke test and read docs/HOW_TO_USE.md.
BRIDGE_LIFECYCLE_ENABLED=false
# Master toggle for the new within-channel scoring formula. When true the
# scraper must send image_gamma, image_count_k, image_uniqueness_alpha
# (the shipped scraper.py already does).
BRIDGE_NEW_SCORING_ENABLED=false

# Featurization tuning (only consulted when BRIDGE_LIFECYCLE_ENABLED=true).
BRIDGE_FEATURIZE_CONCURRENCY=4
BRIDGE_FEATURIZE_PER_JOB_CONCURRENCY=8
BRIDGE_FEATURIZE_ALGORITHM=phash
BRIDGE_FEATURIZE_HASH_SIZE=8
# Global c_i smoothing: c_i = 1 / (1 + alpha * matches_in_other_records).
# 0.85 / 1.0 are the calibrated peaks on the Pexels corpus
# (CALIBRATION_RESULTS.md Run 5/7). Per-channel overrides below take
# precedence when set; leave them unset to inherit these globals.
BRIDGE_FEATURIZE_UNIQUENESS_ALPHA=1.0
BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD=0.85
# Optional per-channel overrides — only set if your corpus exhibits
# different uniqueness characteristics per channel (e.g., monochrome
# footage where tone is a strong discriminator and warrants a stricter
# threshold). On the Pexels calibration corpus all four sweeps confirmed
# the global defaults outperform any per-channel override (Run 7).
# BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD_PHASH=
# BRIDGE_FEATURIZE_UNIQUENESS_THRESHOLD_TONE=
# BRIDGE_FEATURIZE_UNIQUENESS_ALPHA_PHASH=
# BRIDGE_FEATURIZE_UNIQUENESS_ALPHA_TONE=
BRIDGE_STALE_TASK_MS=600000

# Phase 6 LRU eviction for Stash-side image_features rows.
# Set budget to 0 to disable eviction entirely.
BRIDGE_STASH_FEATURE_BUDGET_BYTES=1073741824
BRIDGE_LRU_EVICTION_INTERVAL_S=3600

# Phase 7 soft retirement of the legacy image_hashes table.
# Leave true while you're still validating the new image_features path.
# Flip to false to stop dual-writing pHash and to skip the legacy fallback
# on read. The DROP TABLE is a manual op — see docs/HOW_TO_USE.md §7.3.
BRIDGE_LEGACY_DUAL_WRITE_ENABLED=true
